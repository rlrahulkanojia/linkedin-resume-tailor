{
  "manifest_version": 3,
  "name": "LinkedIn Resume Tailor",
  "version": "1.0.0",
  "description": "Detects an open LinkedIn job, reads the description, and tailors your base resume (LaTeX) to it using your own instructions.",
  "permissions": ["storage", "sidePanel", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.openai.com/*",
    "https://openrouter.ai/*",
    "https://api.anthropic.com/*",
    "https://latex.ytotech.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "LinkedIn Resume Tailor"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
